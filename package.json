{
  "name": "ui-headless-runtime-workspace",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanieleMasone/ui-headless-runtime.git"
  },
  "packageManager": "npm@11.17.0",
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.5.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "npm run dev --workspace @ui-headless-runtime/demo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "unused:check": "knip --no-config-hints",
    "typecheck": "tsc -p tsconfig.workspace.json --noEmit --pretty false",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "playwright test --config=playwright.config.ts --project=chromium --project=firefox --project=webkit --reporter=line",
    "test:a11y": "playwright test --config=playwright.config.ts --project=accessibility --reporter=line",
    "test:acceptance": "playwright test --config=playwright.config.ts --reporter=line",
    "setup:browsers": "playwright install chromium firefox webkit",
    "build": "npm run build:lib && npm run build:demo && npm run build:docs",
    "build:lib": "npm run build --workspace ui-headless-runtime",
    "build:types": "npm run build:types --workspace ui-headless-runtime",
    "build:demo": "node scripts/build-demo.mjs",
    "build:docs": "npm run docs:api && npm run docs:site",
    "build:site": "node scripts/build-site.mjs",
    "site:check": "node scripts/check-site.mjs",
    "docs:api": "typedoc",
    "docs:site": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:check": "node scripts/check-docs.mjs",
    "api:check": "npm run build:types",
    "api:update": "npm run emit:types --workspace ui-headless-runtime && api-extractor run --local --config packages/ui-headless-runtime/api-extractor.json",
    "package:check": "node scripts/package-check.mjs",
    "ci": "npm run format:check && npm run lint && npm run unused:check && npm run typecheck && npm run test:coverage && npm run test:browser && npm run build && npm run docs:check && npm run package:check && npm run build:site && npm run site:check && npm run test:acceptance",
    "release:quality": "npm run format:check && npm run lint && npm run unused:check && npm run typecheck && npm run test:coverage && npm run test:browser && npm run build:lib && npm run docs:api",
    "release:metadata": "node scripts/check-package-version.mjs",
    "release:verify": "npm run release:quality && npm run package:check && npm run release:metadata",
    "preview": "node scripts/serve-site.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "7.58.9",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.0",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "prettier": "3.9.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "4.1.9"
  }
}
